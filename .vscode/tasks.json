{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${command:cmake.buildDirectory}",
                "--target",
                "all",
                "--",
                "-k",
                "1"
            ],
            "options": {
                "env": {
                    "CLICOLOR_FORCE": "1",
                    "FORCE_COLOR": "1"
                }
            },
            "presentation": {
                "clear": true,
                "echo": true,
                "focus": true,
                "panel": "dedicated",
                "reveal": "always",
                "revealProblems": "never",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
